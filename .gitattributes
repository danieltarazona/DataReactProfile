# Normalize all text files to LF in the repo, auto-detect on checkout
* text=auto eol=lf

# Explicitly mark binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
*.tgz binary
*.gz binary
*.zip binary

# Shell scripts must always be LF
*.sh text eol=lf
*.zsh text eol=lf

# Windows bat/cmd files stay CRLF
*.bat text eol=crlf
*.cmd text eol=crlf
